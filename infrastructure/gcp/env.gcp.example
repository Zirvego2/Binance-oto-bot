# =============================================================================
# Google Cloud Run - Ortam Sablonu (zirvego100@gmail.com)
# Bu dosyayi kopyalayin: infrastructure/gcp/env.gcp
# GERCEK DEGERLERI GIT'E EKLEMEYIN.
# =============================================================================

# --- GCP Proje ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_ACCOUNT=zirvego100@gmail.com
ARTIFACT_REPO=bcai

# --- Cloud Run servis adlari ---
SERVICE_API=bcai-api
SERVICE_WEB=bcai-web
SERVICE_WORKER=bcai-worker
JOB_MIGRATE=bcai-migrate

# --- Cloud SQL (PostgreSQL 16) ---
# Ornek: my-project:europe-west1:bcai-db
CLOUDSQL_INSTANCE=
DATABASE_URL=postgresql+asyncpg://bcai_user:CHANGE_ME@/bcai?host=/cloudsql/PROJECT:REGION:INSTANCE

# --- Redis (Memorystore veya Upstash) ---
REDIS_URL=redis://10.0.0.3:6379/0

# --- Uygulama (production) ---
APP_ENV=production
APP_SECRET=CHANGE-TO-LONG-RANDOM-STRING
APP_ENCRYPTION_KEY=CHANGE-TO-32-BYTE-BASE64-KEY
SECURE_COOKIES=true
LOG_LEVEL=INFO

# --- Origin (deploy sonrasi Cloud Run URL'leri ile guncellenir) ---
WEB_ORIGIN=https://bcai-web-XXXXX-ew.a.run.app
API_ORIGIN=https://bcai-api-XXXXX-ew.a.run.app

# --- Binance (canli ortamda dikkatli doldurun) ---
BINANCE_ENV=paper
BINANCE_API_KEY=
BINANCE_API_SECRET=
ENABLE_DEMO_TRADING=false
ENABLE_LIVE_TRADING=false

# --- Firebase ---
FIREBASE_PROJECT_ID=binance-bot-4446e
# Cloud Run'da dosya yerine Secret Manager'dan JSON kullanin:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Web build (API deploy edildikten sonra guncellenir) ---
NEXT_PUBLIC_API_BASE_URL=https://bcai-api-XXXXX-ew.a.run.app/api/v1
NEXT_PUBLIC_WS_BASE_URL=wss://bcai-api-XXXXX-ew.a.run.app/api/v1
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Diger ---
SESSION_COOKIE_NAME=trading_bot_session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
EMERGENCY_CLOSE_PASSWORD=
PROFILE_ACCESS_PASSWORD=
