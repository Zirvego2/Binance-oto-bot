# =============================================================================
# Binance USDS-M Futures Otomatik Isleme Botu - Ornek Ortam Degiskenleri
# Bu dosyayi ".env" olarak kopyalayin ve degerleri kendi ortaminiza gore doldurun.
# GERCEK DEGERLERI ASLA GIT REPOSUNA EKLEMEYIN.
# =============================================================================

# --- Uygulama ---
APP_ENV=development
APP_SECRET=change-this-to-a-long-random-string
APP_ENCRYPTION_KEY=change-this-to-a-32-byte-base64-key

# --- Veritabani & Cache ---
# NOT: docker-compose ile calistirinca DATABASE_URL/REDIS_URL degerleri
# docker-compose.yml icinde postgres/redis container'larina isaret edecek
# sekilde otomatik ezilir (override); asagidaki degerler docker KULLANMADAN
# yerel gelistirme icindir.
DATABASE_URL=postgresql+asyncpg://trading_bot:trading_bot@localhost:5432/trading_bot
REDIS_URL=redis://localhost:6379/0

# --- docker-compose Postgres kimlik bilgileri ---
POSTGRES_USER=trading_bot
POSTGRES_PASSWORD=trading_bot
POSTGRES_DB=trading_bot

# --- Ilk Admin Kullanicisi (yalnizca ilk kurulumda okunur) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# --- Binance Ortami ---
# paper | demo | live
BINANCE_ENV=paper
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Gercek USDS-M Futures endpointleri (BINANCE_ENV=live icin kullanilir)
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com

# Binance Futures Demo/Testnet endpointleri (BINANCE_ENV=demo icin kullanilir)
BINANCE_DEMO_BASE_URL=https://testnet.binancefuture.com
BINANCE_DEMO_WS_URL=wss://stream.binancefuture.com

# --- Ozellik Bayraklari ---
ENABLE_DEMO_TRADING=false
ENABLE_LIVE_TRADING=false
MAX_ALLOWED_LEVERAGE=20

# --- Paper Trading ---
PAPER_START_BALANCE_USDT=100
PAPER_TAKER_COMMISSION_RATE=0.0004
PAPER_FUNDING_SIMULATION_ENABLED=true

# --- CORS / Origin ---
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:8000

# --- Oturum ---
SESSION_COOKIE_NAME=trading_bot_session
SESSION_TTL_MINUTES=480
SECURE_COOKIES=false

# --- Log seviyesi ---
LOG_LEVEL=INFO

# Acil pozisyon kapatma sifresi (Pozisyonlar sayfasi)
EMERGENCY_CLOSE_PASSWORD=1453

# Profil sayfasi baglanti ayarlari sifresi (Binance/Telegram API girisi)
PROFILE_ACCESS_PASSWORD=14531453
PROFILE_UNLOCK_TTL_MINUTES=30

# --- Firebase (musteri hesaplari + Firestore) ---
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# --- Yapay Zeka (OpenAI / ChatGPT) ---
# Market sayfasi "Yapay Zeka Gorusu Al" ve islem aciklamalari icin
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=30
AI_EXPLANATION_ENABLED=true
AI_MARKET_RESEARCH_ENABLED=true
AI_MARKET_RESEARCH_CACHE_SECONDS=300

# --- Telegram Bildirimleri ---
# @BotFather ile bot olusturun, chat_id icin bota /start yazip getUpdates ile alin
# Platform/legacy yedek Telegram (musteriler Profil'den kendi bot token'ini girer)
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Web paneli (docker-compose build-time degiskenleri) ---
# Nginx tek origin uzerinden (port 80) web+API'yi sundugu icin varsayilan
# olarak GORELI yol kullanilir. Nginx KULLANMADAN (web'e direkt 3000 portundan
# erisirseniz) bunlari http://localhost:8000/api/v1 ve ws://localhost:8000/api/v1
# olarak MUTLAK URL'e cevirmeniz gerekir.
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_WS_BASE_URL=/api/v1

# --- Google Cloud Run (production) ---
# Detayli rehber: infrastructure/gcp/DEPLOY.md
# Ortam sablonu: infrastructure/gcp/env.gcp.example
# GCP hesabi: zirvego100@gmail.com
# FIREBASE_SERVICE_ACCOUNT_JSON=   # Cloud Run Secret Manager (dosya yerine)
